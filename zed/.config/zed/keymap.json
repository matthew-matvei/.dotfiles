// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {},
  },
  {
    "context": "VimControl && vim_mode == normal",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "cmd-e": "pane::RevealInProjectPanel",
      "space b d": "pane::CloseActiveItem",
      "space g b": "git::Branch",
      "cmd-g": "git_panel::ToggleFocus",
      "space h": "editor::ToggleInlayHints",
      "space c a": "editor::ToggleCodeActions",
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "bindings": {
      "space b a": "pane::CloseAllItems",
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w ctrl-a": "pane::CloseAllItems",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "space f f": "file_finder::Toggle"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space f": "file_finder::Toggle"
    }
  },
  {
    "context": "!Editor && !Terminal",
    "bindings": {
      "space f f": "file_finder::Toggle"
    }
  },
  {
    "context": "!Editor && !Terminal",
    "unbind": {
      "space f": "file_finder::Toggle"
    }
  }
]
