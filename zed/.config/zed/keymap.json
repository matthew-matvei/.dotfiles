// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {},
  },
  {
    "context": "VimControl && vim_mode == normal",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "cmd-e": "pane::RevealInProjectPanel",
      "space b d": "pane::CloseActiveItem",
      "space g b": "git::Branch",
      "space g g": "git_panel::ToggleFocus",
      "space h": "editor::ToggleInlayHints",
      "space c a": "editor::ToggleCodeActions",
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal) && vim_mode == normal",
    "bindings": {
      "space b a": "pane::CloseAllItems",
    },
  },
  {
    "context": "(VimControl && !menu) || (!Editor && !Terminal)",
    "unbind": {
      "ctrl-w ctrl-a": "pane::CloseAllItems",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "space f f": "file_finder::Toggle",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space f": "file_finder::Toggle",
    },
  },
  {
    "context": "!Editor && !Terminal",
    "bindings": {
      "space f f": "file_finder::Toggle",
    },
  },
  {
    "context": "!Editor && !Terminal",
    "unbind": {
      "space f": "file_finder::Toggle",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "g r": "editor::FindAllReferences",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "g r r": "editor::FindAllReferences",
    },
  },
  {
    "context": "Pane && vim_mode == normal",
    "bindings": {
      "space b o": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "alt-cmd-t": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "Workspace && vim_mode == normal",
    "bindings": {
      "space s g": "pane::DeploySearch",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-f": "pane::DeploySearch",
    },
  },
  {
    "context": "Pane && vim_mode == normal",
    "bindings": {
      "space s g": "pane::DeploySearch",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space s g": "pane::DeploySearch",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-shift-f": "pane::DeploySearch",
    },
  },
  {
    "context": "Editor && extension == md && vim_mode == normal",
    "bindings": {
      "space g p": "markdown::OpenPreviewToTheSide",
    },
  },
  {
    "context": "Editor && extension == md",
    "unbind": {
      "cmd-k v": "markdown::OpenPreviewToTheSide",
    },
  },
  {
    "context": "!Editor && !Terminal",
    "bindings": {
      "space s g": "pane::DeploySearch"
    }
  },
  {
    "context": "!Editor && !Terminal",
    "unbind": {
      "space /": "pane::DeploySearch"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "space s g": "pane::DeploySearch"
    }
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "space /": "pane::DeploySearch"
    }
  }
]
